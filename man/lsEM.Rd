% Generated by hand to match roxygen comments in R/lsEM.R.
\name{func.mtv}
\alias{func.mtv}
\alias{func.vtm}
\alias{vector_to_lower_tri}
\alias{EM_toU}
\alias{EM_toU_ver0}
\title{Latent space network model: lower-triangular utilities and EM fitting}
\usage{
func.mtv(mat)

func.vtm(vec)

vector_to_lower_tri(vec, matrix_size = NULL, fill_upper = 0, fill_diag = 0,
                     symmetric = TRUE, validate = TRUE)

EM_toU(G, d = 3, u1 = 0.5, sig.a = 2, sig.u = 2, tol = 10^(-10), maxiter = 200)

EM_toU_ver0(G, d = 3, tol = 10^(-10), maxiter = 200)
}
\arguments{
\item{mat}{A square matrix.}

\item{vec}{Vector of lower-triangular entries.}

\item{matrix_size}{Optional target matrix dimension \code{n}; if omitted,
inferred from \code{length(vec)}.}

\item{fill_upper}{Value to initially fill the upper triangle with. Default 0.}

\item{fill_diag}{Value to fill the diagonal with. Default 0.}

\item{symmetric}{If \code{TRUE} (default), mirror the lower triangle into
the upper triangle.}

\item{validate}{If \code{TRUE} (default), check/pad/truncate \code{vec}
against a valid triangular length.}

\item{G}{A symmetric adjacency matrix (0/1) (for \code{EM_toU}, may also be
supplied as its strict lower-triangular vector).}

\item{d}{Latent space dimension (including the fixed leading column).
Default 3.}

\item{u1}{(\code{EM_toU} only) Fixed value of the leading latent coordinate
for every node. Default 0.5.}

\item{sig.a}{(\code{EM_toU} only) Prior variance for the intercept
\code{a}. Default 2.}

\item{sig.u}{(\code{EM_toU} only) Prior variance for the free latent
coordinates. Default 2.}

\item{tol}{Convergence tolerance on the max absolute parameter change.
Default 1e-10.}

\item{maxiter}{Maximum number of EM iterations. Default 200.}
}
\value{
\code{func.mtv} returns a numeric vector of the strict
lower-triangular entries of \code{mat}.

\code{func.vtm} and \code{vector_to_lower_tri} return the reconstructed
matrix from a lower-triangular vector (see Description).

\code{EM_toU} and \code{EM_toU_ver0} return a list with \code{U} (the
\code{n x d} latent position matrix) and \code{a} (the estimated intercept).
}
\description{
\code{func.mtv} extracts the strict lower triangle of a matrix as a vector.

\code{func.vtm} reconstructs a symmetric matrix (zero diagonal) from its
lower-triangular vector; \code{vector_to_lower_tri} is a more flexible
version allowing an explicit target size, custom fill values, and input
validation.

\code{EM_toU} fits a regularized latent space network model (Gaussian
priors on the intercept and latent coordinates, initialized from the raw
graph-distance columns).

\code{EM_toU_ver0} is an earlier, unregularized baseline (no priors,
initialized from classical multidimensional scaling of graph distance).
}
